#!/usr/bin/env bash
set -euo pipefail

PATH="/opt/homebrew/bin:/usr/local/bin:/run/current-system/sw/bin:$PATH"

focused="$(aerospace list-workspaces --focused 2>/dev/null || true)"

format_workspace() {
  local id="$1"
  local label="$2"

  if [ "$focused" = "$id" ]; then
    printf "  [%s:%s] " "$id" "$label"
  else
    printf "  %s:%s " "$id" "$label"
  fi
}

status="$(
  format_workspace W web
  format_workspace T term
  format_workspace S ssh
  format_workspace E emacs
  format_workspace M music
  format_workspace A agents
  format_workspace C code
  format_workspace N notes
  format_workspace G git
)"

printf "%s" "$status"
